<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg">

    <!-- TOP PANELS (Effects, Preview, Folder) -->
    <LinearLayout
        android:id="@+id/top_panels"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:weightSum="10"
        android:padding="5dp"
        app:layout_constraintHeight_percent="0.45"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Left: Effects Panel -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.5"
            android:background="@color/cyan_effects"
            android:padding="8dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:text="Effects" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="all fav" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_marginTop="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="effect" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_marginTop="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="effect" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_marginTop="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="► effect" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_marginTop="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="▼ effect" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_marginTop="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="vallu" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_marginStart="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="keyfram" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_marginStart="10dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </ScrollView>

        <!-- Middle: Preview & Color Grading -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="5"
            android:orientation="vertical"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp">
            
            <!-- Color Grading Wheels Box -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.2"
                android:background="@color/grey_wheels_bg">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="colour greding"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black_bg"/>
                <!-- You will add 3 Circular Custom Views here later -->
            </FrameLayout>

            <!-- Video Preview Box (Replace View with GLSurfaceView later) -->
            <FrameLayout
                android:id="@+id/gl_surface_preview"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3"
                android:layout_marginTop="5dp"
                android:background="@color/pink_preview">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="preview"
                    android:textColor="@color/white_text"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <!-- Extra Color Grading -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="5dp"
                android:background="@color/green_extra_color">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="extra colour\ngrading faucher"
                    android:gravity="center"
                    android:textColor="@color/black_bg"
                    android:textStyle="bold"/>
            </FrameLayout>
        </LinearLayout>

        <!-- Right: Folder Panel -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.5"
            android:background="@color/blue_folder">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="folder"
                android:textColor="@color/white_text"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </FrameLayout>

    </LinearLayout>

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/white_text"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/top_panels" />

    <!-- TIMELINE / LAYERS PANEL -->
    <LinearLayout
        android:id="@+id/timeline_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintHeight_percent="0.25"
        app:layout_constraintTop_toBottomOf="@id/divider1">

        <View android:layout_width="match_parent" android:layout_height="25dp" android:background="@color/layer_yellow" android:layout_marginBottom="5dp"/>
        
        <FrameLayout android:layout_width="match_parent" android:layout_height="25dp" android:background="@color/layer_red" android:layout_marginBottom="5dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="layers" android:textColor="@color/white_text" android:textStyle="bold"/>
        </FrameLayout>
        
        <View android:layout_width="match_parent" android:layout_height="25dp" android:background="@color/layer_green"/>

    </LinearLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/white_text"
        app:layout_constraintTop_toBottomOf="@id/timeline_panel" />

    <!-- BOTTOM CONTROLS (Playback & Big Buttons) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="15dp"
        app:layout_constraintTop_toBottomOf="@id/divider2"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Keyframe & Playback controls -->
        <LinearLayout
            android:id="@+id/playback_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">
            
            <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="15dp">
                <!-- Placeholder for Diamond Keyframe icon -->
                <View android:layout_width="20dp" android:layout_height="30dp" android:background="#6EB895" android:rotation="45" android:layout_marginBottom="5dp"/>
                <TextView android:text="keyfram" android:textColor="@color/white_text" android:textStyle="bold" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Playback Icons (Use proper vectors in real app) -->
            <TextView android:text="◀" android:textColor="@color/layer_yellow" android:textSize="30sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="10dp"/>
            <TextView android:text="▶" android:textColor="@color/layer_red" android:textSize="45sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="10dp"/>
            <TextView android:text="▶" android:textColor="@color/layer_yellow" android:textSize="30sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Big Plus (+) Button on right -->
        <TextView
            android:id="@+id/btn_add_element"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textColor="@color/white_text"
            android:textSize="60sp"
            android:textStyle="bold"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Keyboard & Mouse Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="@color/purple_keyboard">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="keyboard"
                    android:textColor="@color/white_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                app:cardBackgroundColor="@color/blue_mouse"
                app:cardCornerRadius="15dp"> <!-- Rounded corners like image -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="mouse"
                    android:textColor="@color/white_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>