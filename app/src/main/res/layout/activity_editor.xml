<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg">

    <LinearLayout android:id="@+id/top_panels" android:layout_width="match_parent" android:layout_height="0dp" android:orientation="horizontal" android:weightSum="10" android:padding="5dp" app:layout_constraintHeight_percent="0.45" app:layout_constraintTop_toTopOf="parent">
        
        <!-- Left: Effects -->
        <ScrollView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2.5" android:background="@color/cyan_effects" android:padding="8dp">
            <TextView android:text="Effects" android:textStyle="bold" android:textColor="@color/black_bg" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </ScrollView>
        
        <!-- Middle: Preview & VideoView -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" android:orientation="vertical" android:layout_marginStart="5dp" android:layout_marginEnd="5dp">
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:background="@color/grey_wheels_bg">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Colour Wheels" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black_bg"/>
            </FrameLayout>
            
            <!-- YAHAN VIDEO PLAY HOGA -->
            <FrameLayout android:id="@+id/gl_surface_preview" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="3" android:layout_marginTop="5dp" android:background="@color/pink_preview">
                <VideoView android:id="@+id/video_preview" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_gravity="center"/>
                <TextView android:id="@+id/tv_preview_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Select Video from Folder" android:textColor="@color/white_text" android:textSize="16sp" android:textStyle="bold"/>
            </FrameLayout>
        </LinearLayout>
        
        <!-- Right: FOLDER PANEL -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2.5" android:background="@color/blue_folder" android:orientation="vertical">
            <Button android:id="@+id/btn_open_folder" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Import Folder" android:textSize="10sp" android:backgroundTint="#222222" android:textColor="#FFFFFF" android:layout_margin="4dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_files" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:id="@+id/divider1" android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/white_text" android:layout_marginTop="5dp" app:layout_constraintTop_toBottomOf="@id/top_panels" />

    <!-- TIMELINE -->
    <LinearLayout android:id="@+id/timeline_panel" android:layout_width="match_parent" android:layout_height="0dp" android:orientation="vertical" android:padding="10dp" app:layout_constraintHeight_percent="0.25" app:layout_constraintTop_toBottomOf="@id/divider1">
        <View android:layout_width="match_parent" android:layout_height="25dp" android:background="@color/layer_yellow" android:layout_marginBottom="5dp"/>
        <FrameLayout android:layout_width="match_parent" android:layout_height="25dp" android:background="@color/layer_red" android:layout_marginBottom="5dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="layers" android:textColor="@color/white_text" android:textStyle="bold"/>
        </FrameLayout>
        <View android:layout_width="match_parent" android:layout_height="25dp" android:background="@color/layer_green"/>
    </LinearLayout>

    <View android:id="@+id/divider2" android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/white_text" app:layout_constraintTop_toBottomOf="@id/timeline_panel" />

    <!-- BOTTOM CONTROLS -->
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="0dp" android:padding="15dp" app:layout_constraintTop_toBottomOf="@id/divider2" app:layout_constraintBottom_toBottomOf="parent">
        <TextView android:id="@+id/btn_add_element" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="@color/white_text" android:textSize="60sp" android:textStyle="bold" app:layout_constraintRight_toRightOf="parent" app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
