<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <!-- Top Heading -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to ProEditor"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Custom Efforts Button -->
    <LinearLayout
        android:id="@+id/ll_custom_efforts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="?android:attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <androidx.cardview.widget.CardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardBackgroundColor="@color/green_plus_1"
            app:cardCornerRadius="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="#000" android:textSize="30sp" android:layout_gravity="center" android:textStyle="bold"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Add Custom Efforts"
            android:textColor="#E0E0E0"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Add Plugin Button -->
    <LinearLayout
        android:id="@+id/ll_add_plugin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:background="?android:attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/ll_custom_efforts">

        <androidx.cardview.widget.CardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardBackgroundColor="@color/green_plus_2"
            app:cardCornerRadius="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="#000" android:textSize="30sp" android:layout_gravity="center" android:textStyle="bold"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Add Plugins"
            android:textColor="#E0E0E0"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Bottom Menu Section (Properly Spaced) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="40dp"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Keyboard Function -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Keyboard" android:textColor="#A0A0A0" android:textSize="14sp" android:layout_marginBottom="12dp"/>
            <androidx.cardview.widget.CardView android:layout_width="55dp" android:layout_height="55dp" app:cardBackgroundColor="@color/pink_plus" app:cardCornerRadius="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌨️" android:textSize="24sp" android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- New Project (ID added here to link with Kotlin) -->
        <LinearLayout
            android:id="@+id/btn_new_project"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Project" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="12dp"/>
            <androidx.cardview.widget.CardView android:layout_width="65dp" android:layout_height="65dp" app:cardBackgroundColor="@color/green_plus_2" app:cardCornerRadius="32dp" app:cardElevation="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="#000" android:textSize="36sp" android:layout_gravity="center" android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- All Projects -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Projects" android:textColor="#A0A0A0" android:textSize="14sp" android:layout_marginBottom="12dp"/>
            <androidx.cardview.widget.CardView android:layout_width="55dp" android:layout_height="55dp" app:cardBackgroundColor="@color/pink_bookmark" app:cardCornerRadius="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📁" android:textSize="24sp" android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
