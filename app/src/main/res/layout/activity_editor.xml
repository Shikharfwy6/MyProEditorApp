<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <!-- 1. TOP HEADER -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="15dp" android:background="@color/bg_panel_dark">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pro Video Editor" android:textColor="@color/text_main" android:textSize="22sp" android:textStyle="bold"/>
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        
        <!-- YAHAN EMOJI HATA KAR ICON LAGAYA -->
        <Button android:layout_width="wrap_content" android:layout_height="40dp" android:text="Keyboard" app:icon="@drawable/ic_keyboard" app:iconTint="@color/text_main" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:textSize="12sp" android:layout_marginEnd="10dp"/>
        <Button android:layout_width="wrap_content" android:layout_height="40dp" android:text="New" app:icon="@drawable/ic_add" app:iconTint="@color/text_main" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:textSize="12sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>

    <!-- 2. MAIN WORKSPACE (3 Columns) -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="4" android:orientation="horizontal">
        
        <!-- Left: Effects Panel -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2.5" android:orientation="vertical" android:background="@color/bg_panel" android:padding="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Effects" android:textColor="@color/text_main" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:layout_width="0dp" android:layout_height="35dp" android:layout_weight="1" android:text="All" android:backgroundTint="@color/accent_green" android:textColor="@color/text_main" android:textSize="12sp"/>
                <Button android:layout_width="0dp" android:layout_height="35dp" android:layout_weight="1" android:text="Fav" android:backgroundTint="@color/button_bg" android:textColor="@color/text_sub" android:textSize="12sp"/>
            </LinearLayout>
            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <Button android:layout_width="match_parent" android:layout_height="40dp" android:text="Blur" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:gravity="left|center_vertical" android:layout_marginBottom="4dp"/>
                    <Button android:layout_width="match_parent" android:layout_height="40dp" android:text="Sharpen" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:gravity="left|center_vertical" android:layout_marginBottom="4dp"/>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/border_color"/>

        <!-- Middle: Preview & Sliders -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5.5" android:orientation="vertical" android:background="@color/bg_main" android:padding="10dp">
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:background="@color/bg_panel" android:layout_marginBottom="10dp">
                <VideoView android:id="@+id/video_preview" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_gravity="center"/>
                <TextView android:id="@+id/tv_preview_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Drop video here" android:textColor="@color/text_sub" android:textSize="16sp"/>
            </FrameLayout>
            <!-- Sliders -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BRIGHTNESS" android:textColor="@color/text_sub" android:textSize="8sp"/>
                    <SeekBar android:layout_width="match_parent" android:layout_height="wrap_content" android:progress="50" android:progressTint="@color/accent_green" android:thumbTint="@color/accent_green"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONTRAST" android:textColor="@color/text_sub" android:textSize="8sp"/>
                    <SeekBar android:layout_width="match_parent" android:layout_height="wrap_content" android:progress="50" android:progressTint="@color/accent_green" android:thumbTint="@color/accent_green"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/border_color"/>

        <!-- Right: Project Folder -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2.5" android:orientation="vertical" android:background="@color/bg_panel" android:padding="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Project Folder" android:textColor="@color/text_main" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            
            <!-- YAHAN FOLDER ICON LAGAYA -->
            <Button android:id="@+id/btn_open_folder" android:layout_width="match_parent" android:layout_height="40dp" android:text="Root Project" app:icon="@drawable/ic_folder" app:iconTint="@color/text_main" android:backgroundTint="@color/accent_green_dark" android:textColor="@color/text_main" android:textSize="12sp" android:gravity="left|center_vertical"/>
            
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_files" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="5dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>

    <!-- 3. MIDDLE TOOLBAR -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="50dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="@color/bg_panel_dark" android:paddingHorizontal="10dp">
        <!-- UNDO / REDO / PLUS ICONS -->
        <Button android:layout_width="wrap_content" android:layout_height="40dp" android:text="Undo" app:icon="@drawable/ic_undo" app:iconTint="@color/text_main" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:textSize="12sp" android:layout_marginEnd="5dp"/>
        <Button android:layout_width="wrap_content" android:layout_height="40dp" android:text="Redo" app:icon="@drawable/ic_redo" app:iconTint="@color/text_main" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:textSize="12sp" android:layout_marginEnd="15dp"/>
        
        <Button android:layout_width="wrap_content" android:layout_height="40dp" android:text="Video" app:icon="@drawable/ic_add" app:iconTint="@color/text_main" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:textSize="12sp" android:layout_marginEnd="5dp"/>
        <Button android:layout_width="wrap_content" android:layout_height="40dp" android:text="Effect" app:icon="@drawable/ic_add" app:iconTint="@color/text_main" android:backgroundTint="@color/button_bg" android:textColor="@color/text_main" android:textSize="12sp" android:layout_marginEnd="5dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>

    <!-- 4. TIMELINE -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.5" android:orientation="vertical" android:background="@color/bg_panel">
        <LinearLayout android:layout_width="match_parent" android:layout_height="40dp" android:orientation="horizontal" android:gravity="center_vertical" android:background="@color/bg_main" android:layout_marginBottom="2dp">
            <TextView android:layout_width="80dp" android:layout_height="match_parent" android:text="Video 1" android:textColor="@color/text_sub" android:textSize="12sp" android:gravity="center" android:background="@color/bg_panel_dark"/>
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="match_parent">
                <LinearLayout android:id="@+id/track_video" android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="5dp"/>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_color"/>

    <!-- 5. PLAYBACK CONTROLS -->
    <RelativeLayout android:layout_width="match_parent" android:layout_height="60dp" android:background="@color/bg_panel_dark" android:paddingHorizontal="20dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:layout_centerInParent="true">
            <!-- PLAY ICON -->
            <com.google.android.material.button.MaterialButton android:layout_width="50dp" android:layout_height="50dp" app:icon="@drawable/ic_play" app:iconSize="30dp" app:iconGravity="textStart" app:iconPadding="0dp" app:iconTint="@color/text_main" android:backgroundTint="@color/accent_green" android:layout_marginEnd="10dp"/>
        </LinearLayout>
        <!-- Big Plus Button -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_add_element" android:layout_width="50dp" android:layout_height="50dp" app:icon="@drawable/ic_add" app:iconSize="30dp" app:iconGravity="textStart" app:iconPadding="0dp" app:iconTint="@color/text_main" android:backgroundTint="@color/accent_green" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
    </RelativeLayout>
</LinearLayout>
