<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- TOP PANELS -->
    <LinearLayout android:id="@+id/top_panels" android:layout_width="match_parent" android:layout_height="0dp" android:orientation="horizontal" android:weightSum="10" android:padding="5dp" app:layout_constraintHeight_percent="0.45" app:layout_constraintTop_toTopOf="parent">
        <!-- Left: Effects -->
        <ScrollView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2.5" android:background="#27E3D6" android:padding="8dp">
            <TextView android:text="Effects\n► colour\n► transform" android:textStyle="bold" android:textColor="#000" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </ScrollView>
        <!-- Middle: Preview -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="5" android:orientation="vertical" android:layout_marginStart="5dp" android:layout_marginEnd="5dp">
            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.2" android:background="#748074">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Colour Wheels" android:textStyle="bold" android:textColor="#000"/>
            </FrameLayout>
            <FrameLayout android:id="@+id/gl_surface_preview" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="3" android:layout_marginTop="5dp" android:background="#CE678E">
                <VideoView android:id="@+id/video_preview" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_gravity="center"/>
                <TextView android:id="@+id/tv_preview_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Select Video from Right" android:textColor="#FFF" android:textStyle="bold"/>
            </FrameLayout>
        </LinearLayout>
        <!-- Right: Folder -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2.5" android:background="#418BA7" android:orientation="vertical">
            <Button android:id="@+id/btn_open_folder" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Import Folder" android:textSize="10sp" android:backgroundTint="#222" android:textColor="#FFF" android:layout_margin="4dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_files" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:id="@+id/divider1" android:layout_width="match_parent" android:layout_height="2dp" android:background="#FFF" android:layout_marginTop="5dp" app:layout_constraintTop_toBottomOf="@id/top_panels" />

    <!-- DYNAMIC TIMELINE LAYERS -->
    <LinearLayout android:id="@+id/timeline_panel" android:layout_width="match_parent" android:layout_height="0dp" android:orientation="vertical" android:padding="10dp" app:layout_constraintHeight_percent="0.25" app:layout_constraintTop_toBottomOf="@id/divider1">
        
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Video Track 1" android:textColor="#FFF" android:textSize="10sp"/>
        
        <!-- YAHAN VIDEOS EK KE BAAD EK ADD HONGE -->
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="40dp" android:background="#333333" android:layout_marginBottom="10dp">
            <LinearLayout android:id="@+id/track_video" android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center_vertical" android:padding="2dp"/>
        </HorizontalScrollView>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Audio Track 1" android:textColor="#FFF" android:textSize="10sp"/>
        
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="30dp" android:background="#222222">
            <LinearLayout android:id="@+id/track_audio" android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center_vertical" android:padding="2dp"/>
        </HorizontalScrollView>

    </LinearLayout>

    <View android:id="@+id/divider2" android:layout_width="match_parent" android:layout_height="2dp" android:background="#FFF" app:layout_constraintTop_toBottomOf="@id/timeline_panel" />

    <!-- BOTTOM CONTROLS -->
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="0dp" android:padding="10dp" app:layout_constraintTop_toBottomOf="@id/divider2" app:layout_constraintBottom_toBottomOf="parent">
        
        <TextView android:id="@+id/btn_add_element" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="#FFF" android:textSize="50sp" android:textStyle="bold" app:layout_constraintRight_toRightOf="parent" app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="60dp" android:orientation="horizontal" android:gravity="center" android:weightSum="2" app:layout_constraintBottom_toBottomOf="parent">
            <androidx.cardview.widget.CardView android:id="@+id/btn_keyboard" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="10dp" app:cardBackgroundColor="#B451E0" app:cardCornerRadius="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Keyboard (108 Keys)" android:textColor="#FFF" android:textSize="14sp" android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView android:id="@+id/btn_mouse" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="10dp" app:cardBackgroundColor="#5C7DE2" app:cardCornerRadius="10dp">
                <TextView android:id="@+id/tv_mouse_btn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="Enable Mouse" android:textColor="#FFF" android:textSize="14sp" android:textStyle="bold" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- HIDDEN MOUSE TRACKPAD OVERLAY -->
    <FrameLayout android:id="@+id/mouse_trackpad" android:layout_width="match_parent" android:layout_height="300dp" android:background="#88000000" app:layout_constraintBottom_toBottomOf="parent" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRACKPAD AREA\nDrag finger here. Tap to Click." android:textColor="#88FFFFFF" android:layout_gravity="center" android:gravity="center" android:textSize="20sp"/>
    </FrameLayout>

    <!-- FLOATING MOUSE POINTER (Initially Hidden) -->
    <TextView android:id="@+id/mouse_pointer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↖️" android:textSize="30sp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintLeft_toLeftOf="parent" android:elevation="100dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
